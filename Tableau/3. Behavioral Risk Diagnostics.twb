                <zone forceUpdate='true' h='9189' id='18' type-v2='text' w='23199' x='20776' y='88649'>
                  <formatted-text>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Revenue Exposure:</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> High-income customers represent the largest share of both retained and churned users, indicating the greatest revenue exposure if churn increases within this segment.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                    <format attr='background-color' value='#f5f5f5' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='9054' id='19' type-v2='text' w='26247' x='45499' y='88649'>
                  <formatted-text>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Data Engagement:</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> Retained clients consume significantly more data (</run>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>3.44 GB</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>) than churned users (</run>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>1.96 GB</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>), marking low data usage as a prime early indicator of detachment.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                    <format attr='background-color' value='#f5f5f5' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='8784' id='20' type-v2='text' w='26385' x='72645' y='88919'>
                  <formatted-text>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Call Neutrality:</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> Call volumes are virtually identical between active (</run>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>50.47</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>) and churned (</run>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>50.63</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>) segments, proving customer call frequency has zero impact on retention.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                    <format attr='background-color' value='#f5f5f5' />
                  </zone-style>
                </zone>
              </zone>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='8' />
              </zone-style>
            </zone>
          </zones>
        </devicelayout>
