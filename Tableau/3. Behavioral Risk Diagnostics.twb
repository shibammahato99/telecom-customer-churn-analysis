          <datasource-dependencies datasource='federated.1keekxu0dorw591e4f9qo17k7gro'>
            <column caption='Churn Rate (%)' datatype='real' default-format='p0.00%' name='[Calculation_5765175963713536]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(INT([churn])) / COUNT([customer_id])' />
            </column>
            <column caption='Age Group' datatype='string' name='[Calculation_5765175968477185]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [age] &gt;= 18 AND [age] &lt;= 25 THEN &quot;18-25&quot;&#10;ELSEIF [age] &gt;= 26 AND [age] &lt;= 35 THEN &quot;26-35&quot;&#10;ELSEIF [age] &gt;= 36 AND [age] &lt;= 45 THEN &quot;36-45&quot;&#10;ELSEIF [age] &gt;= 46 AND [age] &lt;= 60 THEN &quot;46-60&quot;&#10;ELSE &quot;60+&quot;&#10;END' />
            </column>
            <column caption='Salary Band' datatype='string' name='[Calculation_6467764172472320]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='if [estimated_salary] &lt; 30000 then &quot;Low&quot;&#10;&#10;elseif [estimated_salary] &lt; 70000 then &quot;Medium&quot;&#10;&#10;else &quot;High&quot;&#10;&#10;end' />
            </column>
            <column caption='Age' datatype='integer' name='[age]' role='measure' type='quantitative' />
            <column caption='Churn' datatype='boolean' name='[churn]' role='dimension' type='nominal'>
