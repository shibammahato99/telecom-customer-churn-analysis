                <zone h='8378' id='26' type-v2='text' w='23823' x='47368' y='88378'>
                  <formatted-text>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>Behavioral Usage:</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'> Usage is almost identical across segments—churned users average </run>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>5,138 MB</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'> data and </run>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>51 calls</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>, compared to active users at </run>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>5,126 MB</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'> and </run>
                    <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>50 calls</run>
                    <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                    <format attr='background-color' value='#f5f5f5' />
                  </zone-style>
                </zone>
              </zone>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='8' />
