        <zone h='8649' id='25' type-v2='text' w='26108' x='19806' y='88378'>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>Partner Risk:</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>Airtel</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'> leads network churn at </run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>20.34%</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>, while </run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>Bsnl</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'> maintains the lowest churn rate at </run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>19.85%</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>.</run>
          </formatted-text>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='background-color' value='#f5f5f5' />
          </zone-style>
        </zone>
        <zone h='8378' id='26' type-v2='text' w='23823' x='47368' y='88378'>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>Behavioral Usage:</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'> Usage is almost identical across segments—churned users average </run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>5,138 MB</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'> data and </run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>51 calls</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>, compared to active users at </run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>5,126 MB</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'> and </run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>50 calls</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>.</run>
          </formatted-text>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='background-color' value='#f5f5f5' />
          </zone-style>
        </zone>
        <zone h='8514' id='27' type-v2='text' w='24377' x='73546' y='88243'>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>Demographic Stability:</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'> Churn is evenly distributed across age groups, peaking slightly in the </run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>36–45</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'> bracket (</run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>20.17%</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>) and </run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>60+</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'> group (</run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>20.13%</run>
